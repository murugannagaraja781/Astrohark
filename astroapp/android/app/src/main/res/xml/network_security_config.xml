<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Production
    Only HTTPS is allowed by default.
    Cleartext HTTP allowed only for astrohark.com domain.
-->
<network-security-config>
    <!-- Allow cleartext traffic to our server (for backward compatibility) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">astrohark.com</domain>
        <domain includeSubdomains="true">139.59.0.107</domain>
    </domain-config>
</network-security-config>
